{
  "name": "supermarketllm",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "crawl:install": "cd scripts/crawler && npm install && npx playwright install chromium",
    "crawl:basket": "npx tsx scripts/crawler/src/index.ts --mode basket",
    "crawl:debug": "npx tsx scripts/crawler/src/index.ts --mode basket --headless false --debug"
  },
  "dependencies": {
    "expo": "52.0.49",
    "expo-asset": "11.0.5",
    "expo-status-bar": "2.0.1",
    "expo-constants": "17.0.8",
    "expo-localization": "16.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "i18next": "24.2.3",
    "react-i18next": "15.4.1",
    "graphql": "16.10.0"
  },
  "devDependencies": {
    "@types/react": "18.3.18",
    "typescript": "5.3.3"
  },
  "private": true
}
